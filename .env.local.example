# Copy this file to .env.local and fill in your Anthropic API key.
#
#   cp .env.local.example .env.local
#
# Get a key at https://console.anthropic.com/ → API Keys → Create Key
# The key starts with sk-ant-
#
# Required for: the "Extract deal" button on /shows and the Model tab on
# any show detail page. The rest of the app works without it.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
